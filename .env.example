# Supabase Public Client Credentials (Vite Pre-fixed for browser access)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Email verification: add http://localhost:5173/verify-email to Supabase Auth → URL Configuration → Redirect URLs.
# See docs/SUPABASE_EMAIL_VERIFICATION.md for the full checklist (OTP template, SMTP, etc.).

# Supabase Secure Server Credentials (Access only inside server functions/workers)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
